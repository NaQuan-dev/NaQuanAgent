# Default deny: every path is ignored unless explicitly allowed below.
*

# Template repository metadata and root files.
!.gitignore
!.ignore
!README.md
!AGENTS.md
!SUBAGENTS.md
!COMMON_ERRORS.md

# Reusable framework documentation and templates.
!docs/
!docs/**
!agent_rules/
!agent_rules/**
!config/
!config/**
!data/
!data/**
!memory_review/
!memory_review/**
!scripts/
!scripts/**
!subagent/
!subagent/**
!subagents/
!subagents/**

# Runtime, connector state, logs, generated files, and private data.
/.env
/.env.*
/.cc-connect*/
/.runtime/
/runtime/
/agents/
/org_data/
/workspace_data/
/private/
/secrets/
/log/
/logs/
/temp/
/tmp/
/downloads/
/minutes/
/outputs/
/tools/
*.log
*.err.log
*.tmp
*.webp
*.png
*.jpg
*.jpeg
*.mp4
*.mov
*.zip
*.7z
*.rar
__pycache__/
*.pyc

# Local/editor noise.
.DS_Store
Thumbs.db
desktop.ini
.vscode/
.idea/
